---
layout: base.njk
# Match URL to source path (e.g. lore/city.md → /lore/city/), not the title slug.
permalink: lore/{{ page.fileSlug }}/index.html
---

{% set alpha_toc = show_toc and toc_override and toc_override.wrapperClass == "alphabetical" %}
<article class="manilla-folder{% if alpha_toc %} manilla-folder--alpha-toc{% endif %}">
  {% if alpha_toc %}
    <div class="folder-tabs font-typewriter" role="navigation" aria-label="On this page">
      <div class="folder-tab folder-tab--title header-subtitle font-typewriter">{{ title }}</div>
      {{ content | toc(toc_override) | safe }}
    </div>
  {% else %}
    <div class="folder-tab header-subtitle font-typewriter">
      {{ title }}
    </div>
  {% endif %}
  <div class="folder-body">
    <section class="stationary">
      <div class="stationary-header">
        <div class="stationary-header-brand">
          <div class="logo">
            <img src="/images/logo.png" alt="The Mind of Nox"/>
          </div>
        </div>
        <div>
          <p class="header-subtitle font-typewriter">Phoenix Investigations</p>
          <h1 class="header-title font-handwriting">{{ title }}</h1>
        </div>
        <div class="stationary-category-stamp">
          <span class="category-stamp__text">{{ category | default("World Lore") }}</span>
        </div>
      </div>
      <div class="stationary-content">
        {% if image %}
          <aside class="post-polaroid-aside" aria-label="Case photograph">
            <div class="polaroid polaroid--post">
              <span class="tape tape-post-top" aria-hidden="true"></span>
              <div class="polaroid-image">
                <img src="{{ image | polaroidSrc }}" alt="{{ title }}"/>
              </div>
              <div class="polaroid-caption font-handwriting">
                {% if caption %}
                  {{ caption }}{% else %}&nbsp;{% endif %}
              </div>
              <span class="tape tape-post-bottom" aria-hidden="true"></span>
            </div>
          </aside>
        {% endif %}
        <div class="content stationary-body font-typewriter">
          {% if show_toc and not alpha_toc %}
            <div class="page-toc font-typewriter" aria-label="On this page">
              {% if toc_override %}
                {{ content | toc(toc_override) | safe }}
              {% else %}
                {{ content | toc | safe }}
              {% endif %}
            </div>
          {% endif %}
          {{ content | safe }}
        </div>
      </div>
      <div class="stationary-footer">
        {% include "author.njk" %}
      </div>
    </section>
  </div>
</article>