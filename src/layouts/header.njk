<header>
  <div class="header-content">
    <div class="header-content__primary">
      <div class="header-business-card">
        <span class="tape tape-left" aria-hidden="true"></span>
        <span class="tape tape-right" aria-hidden="true"></span>
        <div class="header-business-card__brand">
          <div class="logo">
            <img src="/images/logo.png" alt="The Mind of Nox"/>
          </div>
        </div>
        <div class="header-business-card__text">
          <p class="header-subtitle company-name font-typewriter">
            Phoenix Investigations
          </p>
          <h1 class="header-title font-handwriting">
            <a href="/">The Mind of Nox</a>
          </h1>
          <p class="header-subtitle header-field-notes font-typewriter">
            Field Notes
          </p>
        </div>
        <img
          class="header-business-card__blood-drop"
          src="/images/blood_drop.png"
          alt=""
          width="48"
          height="48"
          decoding="async"
          aria-hidden="true"/>
      </div>
      <div class="header-banner">
        <div class="header-banner__top">
          <div class="header-personnel-sign">
            <span class="tape tape-left" aria-hidden="true"></span>
            <span class="tape tape-right" aria-hidden="true"></span>
            <span class="category-stamp__text">Authorized Personnel Only</span>
          </div>
          <div class="header-icons">
            <a class="header-icon-link" href="/feed/index.xml" aria-label="RSS feed for field notes">
              <div class="header-icon-sticker">
                <i class="fa-solid fa-rss" aria-hidden="true"></i>
              </div>
            </a>
            <a
              class="header-icon-link"
              href="https://discord.gg/JGM7vfZ4D5"
              rel="noopener noreferrer"
              target="_blank"
              aria-label="The Mind of Nox Discord community">
              <div class="header-icon-sticker">
                <i class="fa-brands fa-discord" aria-hidden="true"></i>
              </div>
            </a>
            <a
              class="header-icon-link"
              href="https://themindofnox.wordpress.com"
              rel="noopener noreferrer"
              target="_blank"
              aria-label="The Mind of Nox on WordPress">
              <div class="header-icon-sticker">
                <i class="fa-brands fa-wordpress" aria-hidden="true"></i>
              </div>
            </a>
          </div>
        </div>
        <div class="header-banner__bottom">
          <nav class="header-nav" aria-label="Site">
            <a href="/">
              <span class="header-nav__label">Blog</span>
            </a>
            <a href="/cases/">
              <span class="header-nav__label">Cases</span>
            </a>
            <a href="/nox-knight/">
              <span class="header-nav__label">Nox Knight</span>
            </a>
            <a href="https://tagandtally.quest" rel="noopener noreferrer" target="_blank">
              <span class="header-nav__label">Tag and Tally</span>
            </a>
          </nav>
        </div>
      </div>
    </div>
  </div>
</header>