{
  "name": "the-mind-of-nox",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "eleventy",
    "serve": "eleventy --serve --port=8099",
    "typecheck": "tsc --noEmit",
    "dev": "netlify dev --internal-disable-edge-functions",
    "new-post": "node scripts/new-post.mjs",
    "publish": "node scripts/publish-post.mjs"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.0",
    "@netlify/functions": "^4.3.0",
    "@types/node": "^22.19.0",
    "netlify-cli": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "eleventy-plugin-toc": "^1.1.5",
    "markdown-it-anchor": "^9.2.0",
    "slugify": "^1.6.9"
  }
}
