{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true
  },
  "include": [
    "eleventy.config.ts",
    "netlify/functions/**/*.ts",
    "src/types/**/*"
  ],
  "exclude": ["node_modules", "_site"]
}
